{
  "id": "rdp",
  "name": "RDP",
  "description": "使用 Rust 开发的 RDP 远程桌面 provider",
  "version": "0.1.2",
  "protocol": "rdp",
  "entry": {
    "command": "./onetcli-rdp-helper",
    "args": [],
    "working_dir": null
  },
  "capabilities": {
    "resize": "remote_resize",
    "clipboard_text": true,
    "cursor_shape": true,
    "audio": false,
    "file_transfer": false
  },
  "ui": {
    "icon": "Monitor",
    "default_port": 3389
  }
}
